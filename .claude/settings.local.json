{
  "permissions": {
    "allow": [
      "Bash(gh api:*)",
      "Bash(git reset:*)",
      "Bash(rm -rf features/)",
      "Bash(python .claude/scripts/doc-guardian.py)",
      "Bash(echo \"✓ Exit code: $?\")",
      "Bash(mkdir -p features/auth)",
      "Bash(touch features/auth/api.ts)",
      "Bash(git add:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard HEAD~*)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)",
      "Bash(TRUNCATE*)",
      "Bash(sudo rm*)",
      "Bash(chmod -R 777*)"
    ]
  }
}
